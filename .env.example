# Robo Arena — Environment Variables
# Copy this file to .env and fill in the values before running the project.

# PostgreSQL connection string (required)
# Create a local DB: createdb robo_arena
DATABASE_URL=postgres://user:password@localhost:5432/robo_arena

# API server port (optional, defaults to 8080)
API_PORT=8080

# Frontend dev server port (optional, defaults to 5173)
PORT=5173
